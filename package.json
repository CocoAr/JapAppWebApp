{
  "name": "jap-vocab-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev dist --compatibility-date=2024-11-01 --port 8788",
    "dev:setup": "npm run db:migrate:local && npm run build",
    "validate:vocab": "node scripts/validate-vocabulary.mjs",
    "validate:katakana": "node scripts/validate-katakana.mjs",
    "vocab:apply-taxonomy": "node scripts/apply-vocab-taxonomy.mjs",
    "build": "tsc --noEmit && npm run validate:vocab && npm run validate:katakana && vite build",
    "preview": "wrangler pages dev dist --compatibility-date=2024-11-01",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply jap_vocab_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply jap_vocab_db --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^4.78.0"
  }
}
